		<style type="text/css" id="wp-custom-css">
			.home-page-one .navbar-nav .appilo-mega-menu-lists ul {
    float: left;
}
li.multi-mega-menu>a:after {
    right: -2px;
}
.side-demo .new-demo-badge {
    top: -25px;
    right: 16px;
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    padding: 0 6px;
    position: absolute;
    background-color: #f40000;
    line-height: 20px;
}
a:not([href]):not([tabindex]),
a:not([href]):not([tabindex]):hover{
    color: #ffffff;
} 

/* Ajuste general para todos los logos */
.elementor-image-carousel img {
    max-height: 200px; /* Aumenté un poco la altura máxima */
    width: auto;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.6);
    transition: filter 0.3s ease-in-out, opacity 0.3s ease-in-out;
    padding: 5px; /* Reduce el espacio entre logos */
}

/* Si los escudos aún se ven muy pequeños, aumenta su tamaño */
.elementor-image-carousel img.escudo {
    max-height: 100px; /* Un poco más grande para los escudos */
}

/* Efecto al pasar el mouse */
.elementor-image-carousel img:hover {
    filter: grayscale(0%) opacity(1);
}




/* Cambiar color de fondo del botón Empieza Ahora *//* Cambiar color de fondo del botón Empieza Ahora */
 * /* Cambiar color de fondo del botón Empieza Ahora */
/* Cambiar color de fondo del botón Empieza Ahora */

/* Cambiar color de fondo del botón Empieza Ahora */
.sl-btn.sl-btn-one {
    background-color: #ED2D44 !important;
    color: #ffffff !important; /* Esto pone el texto en blanco para que se lea bien */
    border-color: #ED2D44 !important; /* Para pintar también el borde si lo tiene */
}


/* 1. Fuerza el color en el enlace principal */
a.sl-btn-one {
    color: #ffffff !important;
}

/* 2. CRÍTICO: Fuerza el color en los SPANS internos (aquí suele estar el problema) */
a.sl-btn-one span {
    color: #ffffff !important;
    -webkit-text-fill-color: #ffffff !important; /* Fix para algunos navegadores webkit */
}

/* 3. Asegura que al pasar el mouse (hover) no se vuelva negro otra vez */
a.sl-btn-one:hover,
a.sl-btn-one:hover span {
    color: #ffffff !important;
}

/* Ajustes para los iconos sociales del Footer y su alineación */
.footer__bottom {
    display: flex !important;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
}

.footer__social {
    display: flex !important;
    gap: 15px;
    align-items: center;
    margin-bottom: 0;
}

.footer__social svg {
    width: 20px !important;
    height: 20px !important;
    fill: #666666; /* Gris oscuro para combinar */
    transition: fill 0.3s ease;
    vertical-align: middle;
}

.footer__social a:hover svg {
    fill: #ffffff !important; /* Blanco en hover */
}

/* Centrar logo y redes sociales en móvil */
@media (max-width: 767px) {
    .footer__bottom {
        padding-top: 1px;
    }
    
    .footer__logo {
        width: 100%;
        text-align: center;
        justify-content: center;
    }
    
    .footer__social {
        width: 100%;
        justify-content: center;
    }
}
		</style>
		<style id="kirki-inline-styles"></style></head>

            <body class="home wp-singular page-template page-template-layouts page-template-home-page-layout page-template-layoutshome-page-layout-php page page-id-2681 wp-embed-responsive wp-theme-appilo appilo-default-body-class elementor-default elementor-kit-8 elementor-page elementor-page-2681" id="" data-spy="scroll" data-target="nav" data-offset="50">
            
        <div id="dia-preloader">
            <div class="preloader-inner">
                <div class="preloader-brand">Coonverso</div>
                <div class="preloader-bar-wrap">
                    <div class="preloader-bar-track">
                        <div class="preloader-bar-fill" id="preloaderBarFill"></div>
                    </div>
                </div>
                <div class="preloader-text">Cargando...</div>
            </div>
        </div>
        <style>
            @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;800;900&display=swap");
            div#dia-preloader{position:fixed;left:0;top:0;z-index:99999;width:100%;height:100%;overflow:hidden;background:#ffffff !important;display:flex;align-items:center;justify-content:center;transition:transform 0.8s cubic-bezier(0.77,0,0.175,1),opacity 0.6s ease}
            div#dia-preloader.preloader-done{transform:translateY(-100%);opacity:0}
            .preloader-inner{text-align:center;width:280px}
            .preloader-brand{font-family:"Inter",sans-serif;font-size:42px;font-weight:900;color:#0a0a0a;letter-spacing:-1.5px;margin-bottom:25px;opacity:0;transform:translateY(15px);animation:preloaderFadeIn 0.6s ease forwards 0.2s}
            .preloader-bar-wrap{width:100%;padding:0;opacity:0;animation:preloaderFadeIn 0.5s ease forwards 0.5s}
            .preloader-bar-track{width:100%;height:2px;background-color:#f0f0f0;border-radius:2px;overflow:hidden}
            .preloader-bar-fill{width:0%;height:100%;background-color:#0a0a0a;border-radius:2px;transition:width 0.1s linear}
            .preloader-text{font-family:"Inter",sans-serif;font-size:12px;font-weight:600;color:#666666;letter-spacing:4px;text-transform:uppercase;margin-top:20px;opacity:0;animation:preloaderFadeIn 0.5s ease forwards 0.6s}
            @keyframes preloaderFadeIn{to{opacity:1;transform:translateY(0)}}
        </style>
        <script>
        (function(){
            var bar=document.getElementById("preloaderBarFill");
            var progress=0;
            var interval=setInterval(function(){
                progress+=Math.random()*3+1;
                if(progress>90)progress=90;
                bar.style.width=Math.floor(progress)+"%";
            },50);
            window.addEventListener("load",function(){
                clearInterval(interval);
                var finalStep=setInterval(function(){
                    progress+=2;
                    if(progress>=100){
                        progress=100;
                        bar.style.width="100%";
                        clearInterval(finalStep);
                        setTimeout(function(){
                            var el=document.getElementById("dia-preloader");
                            if(el){el.classList.add("preloader-done")}
                            setTimeout(function(){if(el)el.style.display="none"},900);
                        },400);
                    }else{
                        bar.style.width=Math.floor(progress)+"%";
                    }
                },20);
            });
        })();
